{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KarinCore",
  "version": "1.2.4",
  "identifier": "com.nikitahya.karincore",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "KarinCore",
        "width": 900,
        "height": 700,
        "minWidth": 750,
        "minHeight": 550,
        "decorations": false,
        "transparent": true,
        "zoomHotkeysEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "linux": {
      "deb": {
        "depends": ["xray", "openvpn", "wireguard-tools"],
        "files": {
          "/usr/share/karin-proxy/karincore-sudoers": "system/karincore-sudoers"
        }
      }
    },
    "icon": [
      "/home/nikitahya/Karin/icons/nekobox_icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}